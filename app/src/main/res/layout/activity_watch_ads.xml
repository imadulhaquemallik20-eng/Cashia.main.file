<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/premium_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <!-- Header with Gradient -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/premium_gradient_header"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            android:layout_marginBottom="20dp"
            app:titleTextColor="@android:color/white">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageButton
                    android:id="@+id/backButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@android:color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="📺 Watch Ads"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"/>

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="16dp"
                    android:src="@mipmap/ic_launcher_round"
                    android:contentDescription="Logo"/>

            </RelativeLayout>

        </androidx.appcompat.widget.Toolbar>

        <!-- Balance Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="8dp"
            app:cardCornerRadius="20dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your Balance"
                        android:textSize="14sp"
                        android:textColor="@color/premium_text_secondary"/>

                    <TextView
                        android:id="@+id/coinBalanceText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💰 0 coins"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/premium_primary"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/premium_coin_stack"
                    android:contentDescription="Coins"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Ads Remaining Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="20dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/premium_ad">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today's Limit"
                        android:textSize="14sp"
                        android:textColor="@android:color/white"
                        android:alpha="0.9"/>

                    <TextView
                        android:id="@+id/adsRemainingText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="50/50 ads remaining"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <TextView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:text="📊"
                    android:textSize="36sp"
                    android:gravity="center"
                    android:background="@drawable/circle_background"
                    android:backgroundTint="#33FFFFFF"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Ad Watching Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="400dp"
            app:cardElevation="8dp"
            app:cardCornerRadius="24dp"
            android:layout_marginBottom="40dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="380dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="30dp">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:text="📺"
                    android:textSize="64sp"
                    android:gravity="center"
                    android:background="@drawable/circle_background"
                    android:backgroundTint="@color/premium_ad_light"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Watch a Video Ad"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/premium_text_primary"/>

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⏳ Waiting for ad..."
                    android:textSize="14sp"
                    android:textColor="@color/premium_text_secondary"
                    android:gravity="center"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Earn 2 coins per ad"
                    android:textSize="14sp"
                    android:textColor="@color/premium_text_secondary"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/watchAdButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Watch Ad (+2 coins)"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/premium_ad"
                    app:cornerRadius="16dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="2dp"
            app:cardCornerRadius="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ℹ️ Information"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/premium_text_primary"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Watch up to 50 ads per day"
                    android:textSize="14sp"
                    android:textColor="@color/premium_text_secondary"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Each ad gives you 2 coins"
                    android:textSize="14sp"
                    android:textColor="@color/premium_text_secondary"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• New ads available daily"
                    android:textSize="14sp"
                    android:textColor="@color/premium_text_secondary"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Back to Main Button -->
        <Button
            android:id="@+id/backButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back to Main"
            android:textSize="14sp"
            android:backgroundTint="@color/premium_text_tertiary"
            app:cornerRadius="12dp"/>

    </LinearLayout>

</ScrollView>