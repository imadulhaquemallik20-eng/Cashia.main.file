<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/premium_background">

        <!-- Premium Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/premium_gradient_header">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/toolbarTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Jackpot"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"/>

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="16dp"
                    android:src="@mipmap/ic_launcher_round"/>

            </RelativeLayout>

        </androidx.appcompat.widget.Toolbar>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <!-- Balance Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="8dp"
                    app:cardCornerRadius="20dp"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@android:color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Your Balance"
                                android:textSize="14sp"
                                android:textColor="@color/premium_text_secondary"/>

                            <TextView
                                android:id="@+id/coinBalanceText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💰 0 coins"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/premium_primary"
                                android:layout_marginTop="4dp"/>

                        </LinearLayout>

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/premium_coin_stack"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Stats Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="4dp"
                    app:cardCornerRadius="16dp"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@android:color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="📊 Today's Stats"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/premium_text_primary"
                            android:layout_marginBottom="12dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Spins Today:"
                                android:textSize="14sp"
                                android:textColor="@color/premium_text_secondary"/>

                            <TextView
                                android:id="@+id/spinsTodayText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="0/50"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/premium_primary"
                                android:gravity="end"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Winnings Today:"
                                android:textSize="14sp"
                                android:textColor="@color/premium_text_secondary"/>

                            <TextView
                                android:id="@+id/winningsTodayText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="0/100"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/premium_success"
                                android:gravity="end"/>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/premium_text_tertiary"
                            android:alpha="0.3"
                            android:layout_marginVertical="8dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Cost per Spin:"
                                android:textSize="14sp"
                                android:textColor="@color/premium_text_secondary"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="1 coin"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/premium_warning"
                                android:gravity="end"/>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Slot Machine Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="12dp"
                    app:cardCornerRadius="24dp"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@android:color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:gravity="center">

                        <!-- Reels Container -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="3"
                            android:gravity="center"
                            android:layout_marginBottom="24dp">

                            <TextView
                                android:id="@+id/reel1Text"
                                android:layout_width="0dp"
                                android:layout_height="120dp"
                                android:layout_weight="1"
                                android:text="🍒"
                                android:textSize="60sp"
                                android:gravity="center"
                                android:background="@drawable/premium_card_background"
                                android:layout_margin="4dp"
                                android:padding="8dp"
                                android:elevation="4dp"/>

                            <TextView
                                android:id="@+id/reel2Text"
                                android:layout_width="0dp"
                                android:layout_height="120dp"
                                android:layout_weight="1"
                                android:text="🍋"
                                android:textSize="60sp"
                                android:gravity="center"
                                android:background="@drawable/premium_card_background"
                                android:layout_margin="4dp"
                                android:padding="8dp"
                                android:elevation="4dp"/>

                            <TextView
                                android:id="@+id/reel3Text"
                                android:layout_width="0dp"
                                android:layout_height="120dp"
                                android:layout_weight="1"
                                android:text="🍊"
                                android:textSize="60sp"
                                android:gravity="center"
                                android:background="@drawable/premium_card_background"
                                android:layout_margin="4dp"
                                android:padding="8dp"
                                android:elevation="4dp"/>

                        </LinearLayout>

                        <!-- Spin Button -->
                        <Button
                            android:id="@+id/spinButton"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:text="SPIN (1 coin)"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:backgroundTint="@color/premium_jackpot"
                            app:cornerRadius="16dp"
                            android:layout_marginBottom="16dp"/>

                        <!-- Result Message -->
                        <TextView
                            android:id="@+id/resultText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:padding="12dp"
                            android:visibility="gone"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Paytable Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="4dp"
                    app:cardCornerRadius="16dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@android:color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="💰 Paytable (3 of a kind)"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/premium_text_primary"
                            android:layout_marginBottom="12dp"/>

                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="2"
                            android:rowCount="7">

                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="🍒 Cherries" android:textSize="14sp" android:padding="4dp" android:textColor="@color/premium_text_secondary"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="2 coins" android:textSize="14sp" android:textColor="@color/premium_success" android:padding="4dp" android:gravity="end"/>

                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="🍋 Lemons" android:textSize="14sp" android:padding="4dp" android:textColor="@color/premium_text_secondary"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="3 coins" android:textSize="14sp" android:textColor="@color/premium_success" android:padding="4dp" android:gravity="end"/>

                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="🍊 Oranges" android:textSize="14sp" android:padding="4dp" android:textColor="@color/premium_text_secondary"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="4 coins" android:textSize="14sp" android:textColor="@color/premium_success" android:padding="4dp" android:gravity="end"/>

                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="🍇 Grapes" android:textSize="14sp" android:padding="4dp" android:textColor="@color/premium_text_secondary"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="5 coins" android:textSize="14sp" android:textColor="@color/premium_success" android:padding="4dp" android:gravity="end"/>

                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="💰 Money Bag" android:textSize="14sp" android:padding="4dp" android:textColor="@color/premium_text_secondary"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="10 coins" android:textSize="14sp" android:textColor="@color/premium_success" android:padding="4dp" android:gravity="end"/>

                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="💎 Diamond" android:textSize="14sp" android:padding="4dp" android:textColor="@color/premium_text_secondary"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="15 coins" android:textSize="14sp" android:textColor="@color/premium_success" android:padding="4dp" android:gravity="end"/>

                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="7️⃣ Seven" android:textSize="14sp" android:textStyle="bold" android:padding="4dp" android:textColor="@color/premium_text_secondary"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:text="20 coins" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/premium_jackpot" android:padding="4dp" android:gravity="end"/>

                        </GridLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Info Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="2dp"
                    app:cardCornerRadius="16dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@android:color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🎰 How to Play"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/premium_text_primary"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• Pay 1 coin to spin the reels"
                            android:textSize="14sp"
                            android:textColor="@color/premium_text_secondary"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• Match 3 symbols to win"
                            android:textSize="14sp"
                            android:textColor="@color/premium_text_secondary"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• Higher value symbols = bigger prizes!"
                            android:textSize="14sp"
                            android:textColor="@color/premium_text_secondary"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_menu"
        app:itemIconTint="@color/white"
        app:itemTextColor="@color/white"
        android:background="@color/premium_primary_dark"/>

</androidx.drawerlayout.widget.DrawerLayout>