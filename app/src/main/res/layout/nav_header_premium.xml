<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/premium_gradient_header"
    android:padding="20dp">

    <!-- Make avatar round with circular background -->
    <FrameLayout
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="12dp">

        <!-- Emoji Avatar (TextView) - Hidden by default when image exists -->
        <TextView
            android:id="@+id/navAvatarEmoji"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="👤"
            android:textSize="42sp"
            android:gravity="center"
            android:background="@drawable/circle_background"
            android:backgroundTint="#33FFFFFF"
            android:visibility="visible"/>

        <!-- Image Avatar (ImageView) - Round with circle crop -->
        <ImageView
            android:id="@+id/navAvatarImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@drawable/circle_background"
            android:backgroundTint="#33FFFFFF"
            android:visibility="gone"/>

    </FrameLayout>

    <TextView
        android:id="@+id/navUsername"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Username"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"/>

    <TextView
        android:id="@+id/navEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="email@example.com"
        android:textSize="13sp"
        android:textColor="@android:color/white"
        android:alpha="0.8"
        android:layout_marginTop="4dp"/>

</LinearLayout>