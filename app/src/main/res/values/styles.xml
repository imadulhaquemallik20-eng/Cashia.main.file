<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Premium Text Style -->
    <style name="PremiumText" parent="android:style/TextAppearance">
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Premium Card Style -->
    <style name="PremiumCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/premium_card_background</item>
        <item name="android:elevation">8dp</item>
        <item name="android:translationZ">2dp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <!-- Premium Game Button Style -->
    <style name="PremiumGameButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">140dp</item>
        <item name="android:background">@drawable/premium_game_card</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:elevation">4dp</item>
    </style>

    <!-- Premium Text Styles - Now properly inheriting from PremiumText -->
    <style name="PremiumText.Title" parent="PremiumText">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/premium_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="PremiumText.Subtitle" parent="PremiumText">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/premium_text_secondary</item>
    </style>

    <style name="PremiumText.Body" parent="PremiumText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/premium_text_tertiary</item>
    </style>

    <!-- Premium Number Style -->
    <style name="PremiumText.Number" parent="PremiumText">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/premium_primary</item>
        <item name="android:fontFamily">sans-serif-black</item>
    </style>

    <!-- Custom AlertDialog Style -->
    <style name="CustomAlertDialog" parent="ThemeOverlay.AppCompat.Dialog.Alert">
        <!-- Background -->
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>

        <!-- Colors -->
        <item name="android:colorPrimary">@color/premium_primary</item>
        <item name="android:colorAccent">@color/premium_primary</item>

        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/premium_text_primary</item>
        <item name="android:textColorSecondary">@color/premium_text_secondary</item>

        <!-- Button Styles -->
        <item name="android:buttonBarPositiveButtonStyle">@style/DialogButton.Positive</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/DialogButton.Negative</item>
        <item name="android:buttonBarNeutralButtonStyle">@style/DialogButton.Neutral</item>

        <!-- Title Style -->
        <item name="android:windowTitleStyle">@style/DialogTitle</item>

        <!-- Animation -->
        <item name="android:windowEnterAnimation">@anim/dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/dialog_exit</item>
    </style>

    <!-- Dialog Title Style -->
    <style name="DialogTitle" parent="TextAppearance.AppCompat.Title">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/premium_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingTop">24dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
    </style>

    <!-- Dialog Message Style -->
    <style name="DialogMessage" parent="TextAppearance.AppCompat.Subhead">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/premium_text_secondary</item>
        <item name="android:lineSpacingExtra">4dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <!-- Positive Button (Confirm/Logout) -->
    <style name="DialogButton.Positive" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/premium_primary</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:minWidth">100dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Negative Button (Cancel) -->
    <style name="DialogButton.Negative" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/premium_text_secondary</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:minWidth">100dp</item>
    </style>

    <!-- Neutral Button -->
    <style name="DialogButton.Neutral" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/premium_text_secondary</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <!-- Add this to your styles.xml inside the Theme.Cashia or as a separate style -->
    <style name="PasswordToggleStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="passwordToggleEnabled">true</item>
        <item name="passwordToggleTint">@color/premium_primary</item>
        <item name="endIconMode">password_toggle</item>
        <item name="endIconTint">@color/premium_primary</item>
        <item name="colorControlNormal">@color/premium_primary</item>
        <item name="colorControlActivated">@color/premium_primary</item>
    </style>
</resources>